# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Porta do servidor (padrao: 3000)
PORT=3000

# Credenciais do administrador
ADMIN_USER=admin
ADMIN_PASS=troque-para-senha-forte

# Chave secreta JWT (gere uma aleatoria: openssl rand -hex 32)
JWT_SECRET=mude-esta-chave-em-producao
